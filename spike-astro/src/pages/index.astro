---
import Base from "../layouts/Base.astro";
import OrchestratorCarousel from "../components/orchestrator-preview/OrchestratorCarousel.astro";
import { loadAllScripts } from "../lib/opx";

const scripts = loadAllScripts();
// `import.meta.env.BASE_URL` always ends with a slash, so we can append
// the page slug directly. Local dev: "/"; Pages deploy: "/trainer-demo-deploy/".
const base = import.meta.env.BASE_URL;

const featureCards = [
  {
    title: "Catalog",
    tagline: "Pre-built, ready to deploy",
    desc: "Browse curated demo templates aligned to Microsoft Learn courses. Pick one, run azd up, walk into class with a working demo.",
    href: `${base}gallery`,
    cta: "Browse the catalog",
    accent: "from-[#8661C5] to-[#C03BC4]",
  },
  {
    title: "BYOD — Azure",
    tagline: "Bring Your Own Demo",
    desc: "An agentic demo builder powered by GitHub Copilot. Describe the Azure workload you want to teach and let the agents scaffold a working azd template for you.",
    href: `${base}byod-azure`,
    cta: "Build an Azure demo",
    accent: "from-[#0078D4] to-[#49C5B1]",
  },
  {
    title: "BYOD — Copilot Studio",
    tagline: "Bring Your Own Demo",
    desc: "The same agentic builder, focused on Copilot Studio. Generate ready-to-import agent solutions, topics, and connectors from a plain-English description.",
    href: `${base}byod-copilot-studio`,
    cta: "Build a Copilot Studio demo",
    accent: "from-[#C03BC4] to-[#8661C5]",
  },
];
---
<Base title="Trainer Demo Deploy — Demos, ready in minutes.">
  <!-- Ambient gradients -->
  <section class="relative overflow-hidden">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-40 -left-32 w-[1400px] h-[700px] rounded-full opacity-60 dark:opacity-80"
           style="background: radial-gradient(closest-side, rgba(134,97,197,0.35), transparent 70%);"></div>
      <div class="absolute -top-24 right-[-20%] w-[1200px] h-[600px] rounded-full opacity-50 dark:opacity-70"
           style="background: radial-gradient(closest-side, rgba(192,59,196,0.30), transparent 72%);"></div>
    </div>

    <!-- HERO: left text + right "screenshot" -->
    <div class="max-w-7xl mx-auto px-6 pt-16 pb-16 md:pt-24 md:pb-20 grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-12 items-center">
      <!-- LEFT: Demo Deploy headline + CTAs -->
      <div class="min-w-0">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/70 dark:bg-white/10 border border-neutral-200 dark:border-neutral-700 text-xs font-medium text-neutral-700 dark:text-neutral-300 mb-6">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-[#C03BC4]"></span>
          Spike — Astro 5 + Tailwind v4
        </div>
        <h1 class="text-5xl md:text-6xl font-semibold tracking-tight leading-[1.02] mb-6">
          <span class="block text-neutral-900 dark:text-neutral-50">Demo.</span>
          <span class="block bg-clip-text text-transparent bg-gradient-to-r from-[#8661C5] via-[#C03BC4] to-[#8661C5]">
            Deploy.
          </span>
        </h1>
        <p class="max-w-xl text-lg text-neutral-600 dark:text-neutral-300 mb-8 leading-relaxed">
          Pick a curated template, or describe your own. Trainer Demo Deploy hands you
          a working Azure or Copilot Studio demo — provisioned in minutes — so you can
          walk into class focused on teaching, not setup.
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <a href={`${import.meta.env.BASE_URL}gallery`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-[#8661C5] hover:bg-[#C03BC4] text-white text-sm font-medium transition-colors shadow-lg shadow-[#8661C5]/30">
            Browse the catalog
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href="https://github.com/MicrosoftLearning/trainer-demo-deploy" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md border border-neutral-300 dark:border-neutral-700 hover:border-[#8661C5] dark:hover:border-[#C5B4E3] text-sm font-medium">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.78 1.19 1.78 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.27-5.24-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.17a11.04 11.04 0 0 1 5.79 0c2.2-1.48 3.17-1.17 3.17-1.17.63 1.58.23 2.75.12 3.04.74.8 1.18 1.82 1.18 3.07 0 4.4-2.7 5.36-5.27 5.65.41.36.78 1.06.78 2.14v3.17c0 .31.21.68.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/></svg>
            View on GitHub
          </a>
        </div>
        <div class="mt-6 text-xs text-neutral-500 dark:text-neutral-400">
          <code class="px-1.5 py-0.5 rounded bg-neutral-100 dark:bg-neutral-800 text-[0.95em]">azd init -t &lt;template&gt;</code>
          <span class="mx-1">·</span>
          <code class="px-1.5 py-0.5 rounded bg-neutral-100 dark:bg-neutral-800 text-[0.95em]">azd up</code>
        </div>
      </div>

      <!-- RIGHT: Orchestrator Preview carousel (cycles through every .opx.yaml under src/scripts/) -->
      <OrchestratorCarousel scripts={scripts} />
    </div>
  </section>

  <!-- THREE PATHS -->
  <section id="paths" class="max-w-7xl mx-auto px-6 pb-24">
    <div class="text-center mb-10">
      <div class="text-xs uppercase tracking-widest text-[#8661C5] dark:text-[#C5B4E3] font-semibold mb-2">Three ways in</div>
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">Pick a path</h2>
      <p class="mt-3 text-neutral-600 dark:text-neutral-300 max-w-2xl mx-auto">
        Start from the curated catalog, or let agents build a brand-new demo with you.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {featureCards.map((c) => (
        <a href={c.href} class="group relative overflow-hidden rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 p-6 transition-all duration-200 hover:-translate-y-1 hover:shadow-xl hover:shadow-[#8661C5]/20 hover:border-[#8661C5]/40 dark:hover:border-[#C5B4E3]/40 flex flex-col">
          <div class={`absolute inset-x-0 top-0 h-1 bg-gradient-to-r ${c.accent}`}></div>
          <div class="text-[11px] uppercase tracking-wider font-semibold text-neutral-500 dark:text-neutral-400 mt-1 mb-1">{c.tagline}</div>
          <h3 class="text-xl font-semibold mb-2">{c.title}</h3>
          <p class="text-sm text-neutral-600 dark:text-neutral-300 leading-relaxed mb-5 flex-1">{c.desc}</p>
          <span class="inline-flex items-center gap-1 text-sm font-medium text-[#8661C5] dark:text-[#C5B4E3] group-hover:gap-2 transition-all">
            {c.cta}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>
</Base>
