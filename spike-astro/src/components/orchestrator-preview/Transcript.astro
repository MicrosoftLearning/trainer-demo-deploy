---
import type { Step } from "../../lib/opx";
import { stepKind } from "../../lib/opx";
import UserStep from "./steps/UserStep.astro";
import AgentStep from "./steps/AgentStep.astro";
import ToolStep from "./steps/ToolStep.astro";
import FilesStep from "./steps/FilesStep.astro";
import SummaryStep from "./steps/SummaryStep.astro";
import StatusStep from "./steps/StatusStep.astro";

type Props = { steps: Step[]; height?: number; speed?: number };
const { steps, height = 260, speed = 1 } = Astro.props;
const duration = Math.max(8, Math.round(36 / speed));
---
<div
  class="opx-viewport relative overflow-hidden"
  style={`height:${height}px`}
>
  <div
    class="opx-scroll px-4 py-4 space-y-3 text-[11.5px] leading-snug text-[#c9d1d9]"
    style={`animation-duration:${duration}s; --opx-end:${height - 20}px;`}
  >
    {steps.map((s) => {
      const k = stepKind(s);
      if (k === "user")    { const { handle, avatar, body, when } = (s as any).user;       return <UserStep handle={handle} initials={avatar.initials} gradient={avatar.gradient} body={body} when={when} />; }
      if (k === "agent")   { const { body, code } = (s as any).agent;                       return <AgentStep body={body} code={code} />; }
      if (k === "tool")    { const { kind, title, detail, result } = (s as any).tool;       return <ToolStep kind={kind} title={title} detail={detail} result={result} />; }
      if (k === "files")   { const { files } = s as any;                                    return <FilesStep files={files} />; }
      if (k === "summary") { const { title, lead, bullets } = (s as any).summary;           return <SummaryStep title={title} lead={lead} bullets={bullets} />; }
      const { kind: sk, text } = (s as any).status;                                         return <StatusStep kind={sk} text={text} />;
    })}
    <div class="h-8"></div>
  </div>
</div>
