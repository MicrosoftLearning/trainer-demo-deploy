---
import Icon from "../Icon.astro";
import { renderMarkdown, highlight } from "../../../lib/markdown";
type Props = {
  body: string;
  code?: { lang: string; source: string };
};
const { body, code } = Astro.props;
---
<div class="space-y-3">
  <div class="flex items-center gap-2">
    <span class="w-6 h-6 rounded-md bg-[#161b22] border border-[#30363d] flex items-center justify-center text-[#c9d1d9]">
      <Icon name="github" size={14} />
    </span>
    <span class="text-xs font-semibold text-[#c9d1d9]">GitHub Copilot</span>
  </div>
  <div class="ml-8 space-y-3">
    <!-- Typing indicator (player mode: visible while parent step is in `typing` state) -->
    <div class="opx-typing-indicator items-center gap-0.5 py-1">
      <span></span><span></span><span></span>
    </div>
    <div class="opx-agent-body space-y-3">
      <div class="opx-prose text-[#c9d1d9]" set:html={renderMarkdown(body)} />
      {code && (
        <pre class="rounded-md bg-[#161b22] border border-[#30363d] p-3 overflow-x-auto text-[12px] font-mono leading-relaxed text-[#c9d1d9]"><code set:html={highlight(code.lang, code.source)} /></pre>
      )}
    </div>
  </div>
</div>
